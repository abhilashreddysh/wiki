<svg
  viewBox="0 0 900 520"
  width="100%"
  style="max-width:900px;margin:2rem auto;display:block;font-family:system-ui,sans-serif;"
>
  <!-- DISKS -->
  <text x="150" y="25" font-size="13" text-anchor="middle" fill="#444">Physical Disks</text>
  <rect x="50" y="35" width="200" height="40" rx="6" fill="#f5f5f5" stroke="#ccc" />
  <rect x="300" y="35" width="200" height="40" rx="6" fill="#f5f5f5" stroke="#ccc" />
  <text x="150" y="60" text-anchor="middle" font-size="13">/dev/sda (500G)</text>
  <text x="400" y="60" text-anchor="middle" font-size="13">/dev/sdb (1T)</text>

  <!-- ARROWS -->
  <line x1="150" y1="75" x2="150" y2="110" stroke="#aaa" />
  <line x1="400" y1="75" x2="400" y2="110" stroke="#aaa" />

  <!-- PHYSICAL VOLUMES -->
  <text x="275" y="105" font-size="13" text-anchor="middle" fill="#444">Physical Volumes (PVs)</text>

  <rect x="50" y="115" width="200" height="70" rx="6" fill="#eef6ff" stroke="#8ab4f8" />
  <rect x="300" y="115" width="200" height="70" rx="6" fill="#eef6ff" stroke="#8ab4f8" />

  <text x="150" y="135" text-anchor="middle" font-size="13">PV1</text>
  <text x="400" y="135" text-anchor="middle" font-size="13">PV2</text>

  <!-- PHYSICAL EXTENTS -->
  <g fill="#cfe3ff">
    <rect x="60" y="150" width="25" height="25" />
    <rect x="90" y="150" width="25" height="25" />
    <rect x="120" y="150" width="25" height="25" />
    <rect x="150" y="150" width="25" height="25" />
    <rect x="180" y="150" width="25" height="25" />

    <rect x="310" y="150" width="25" height="25" />
    <rect x="340" y="150" width="25" height="25" />
    <rect x="370" y="150" width="25" height="25" />
    <rect x="400" y="150" width="25" height="25" />
    <rect x="430" y="150" width="25" height="25" />
  </g>

  <text x="520" y="168" font-size="12" fill="#555">Physical Extents (PEs)</text>

  <!-- ARROW TO VG -->
  <line x1="275" y1="185" x2="275" y2="230" stroke="#aaa" />

  <!-- VOLUME GROUP -->
  <text x="275" y="225" font-size="13" text-anchor="middle" fill="#444">Volume Group (VG)</text>

  <rect x="50" y="235" width="450" height="90" rx="8" fill="#e8f5e9" stroke="#81c784" />
  <text x="275" y="255" text-anchor="middle" font-size="14" font-weight="600">VG_SYSTEM</text>

  <!-- VG EXTENTS -->
  <g>
    <rect x="70" y="270" width="40" height="35" fill="#bbdefb" />
    <rect x="115" y="270" width="40" height="35" fill="#bbdefb" />
    <rect x="160" y="270" width="40" height="35" fill="#c8e6c9" />
    <rect x="205" y="270" width="40" height="35" fill="#c8e6c9" />
    <rect x="250" y="270" width="40" height="35" fill="#ffe0b2" />
    <rect x="295" y="270" width="40" height="35" fill="#ffe0b2" />
    <rect x="340" y="270" width="40" height="35" fill="#e1bee7" />
    <rect x="385" y="270" width="40" height="35" fill="#e1bee7" />
  </g>

  <text x="520" y="290" font-size="12" fill="#555">
    Extents pooled from all PVs
  </text>

  <!-- ARROW TO LVs -->
  <line x1="275" y1="325" x2="275" y2="360" stroke="#aaa" />

  <!-- LOGICAL VOLUMES -->
  <text x="275" y="355" font-size="13" text-anchor="middle" fill="#444">Logical Volumes (LVs)</text>

  <rect x="60" y="370" width="220" height="60" rx="6" fill="#fff3e0" stroke="#ffb74d" />
  <rect x="300" y="370" width="200" height="60" rx="6" fill="#fff3e0" stroke="#ffb74d" />

  <text x="170" y="395" text-anchor="middle" font-size="14">LV_root</text>
  <text x="170" y="412" text-anchor="middle" font-size="11" fill="#555">ext4</text>

  <text x="400" y="395" text-anchor="middle" font-size="14">LV_home</text>
  <text x="400" y="412" text-anchor="middle" font-size="11" fill="#555">xfs</text>

  <!-- NOTE -->
  <text x="275" y="455" text-anchor="middle" font-size="12" fill="#666">
    LVs are built from extents spanning multiple physical disks
  </text>
</svg>
